#!/usr/bin/env python

"""
Compresses all font files in the given subtree with gzip.
font.json files become font.json.gz files.
.svg font variant files become .svgz files.

Be warned, this will delete the original .json and .svg files!
"""

import os
import sys
import gzip
import shutil
import re

try:
    font_dir = sys.argv[1]
except:
    print(f"Usage: {sys.argv[0]} font_dir", file=sys.stderr)
    sys.exit(1)

def compress(inpath, outpath):
    print(f"{inpath} -> {outpath}")
    with open(inpath, "rb") as infile,\
         gzip.open(outpath, "wb") as outfile:
        shutil.copyfileobj(infile, outfile)
    os.remove(inpath)

for root, dirs, files in os.walk(font_dir):
    for file in files:
        fullpath = os.path.join(root, file)
        if file.endswith(".svg"):
            compress(fullpath, re.sub(".svg$", ".svgz", fullpath))
        elif file.endswith(".json"):
            compress(fullpath, re.sub(".json$", ".json.gz", fullpath))
