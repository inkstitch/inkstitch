{
  "version": 6,
  "configurePresets": [
    {
      "name": "release",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "INKSCAPE_DIR": "$env{INKSCAPE_DIR}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "workflowPresets": [
    {
      "name": "release",
      "steps": [
        {"type": "configure", "name": "release"},
        {"type": "build",     "name": "release"}
      ]
    }
  ]
}
